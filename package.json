{
  "name": "xiv-arbitrage",
  "version": "0.1.0",
  "private": true,
  "description": "FFXIV market arbitrage explorer powered by Universalis and XIVAPI.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --reporter=append-only build",
    "check": "pnpm -r check",
    "dev": "pnpm --parallel dev",
    "format": "oxfmt --check . 2>/dev/null",
    "format:fix": "oxfmt . 2>/dev/null",
    "lint": "oxlint --quiet . 2>/dev/null",
    "start": "pnpm --filter @xiv-arbitrage/api start",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/node": "^25.9.3",
    "husky": "^9.1.7",
    "oxlint": "^1.70.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "@fastify/static@>=8.0.0 <=9.1.0": ">=9.1.1",
      "esbuild@>=0.27.3 <0.28.1": ">=0.28.1"
    }
  }
}
