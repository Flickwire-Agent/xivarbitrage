{
  "name": "xiv-arbitrage",
  "version": "0.1.0",
  "private": true,
  "description": "FFXIV market arbitrage explorer powered by Universalis and XIVAPI.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --reporter=append-only build",
    "check": "pnpm -r check",
    "dev": "pnpm --parallel dev",
    "format": "oxfmt --check . 2>/dev/null",
    "format:fix": "oxfmt . 2>/dev/null",
    "lint": "oxlint --quiet . 2>/dev/null",
    "start": "pnpm --filter @xiv-arbitrage/api start",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@types/node": "^22.10.5",
    "husky": "^9.1.7",
    "oxlint": "^0.15.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@9.15.4"
}
